---
import type { Lang } from "@/i18n";

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const otherLang = lang === "es" ? "en" : "es";
const label = lang === "es" ? "EN" : "ES";
const title = lang === "es" ? "Switch to English" : "Cambiar a Español";
---

<a
	href={`/${otherLang}/`}
	class="no-print inline-flex items-center gap-2 rounded-lg px-3 py-2 text-sm font-medium text-skin-base ring-1 ring-skin-muted transition-all hover:ring-skin-hue"
	title={title}
>
	<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
		<circle cx="12" cy="12" r="10"></circle>
		<path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path>
		<path d="M2 12h20"></path>
	</svg>
	<span>{label}</span>
</a>
