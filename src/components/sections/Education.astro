---
import Section from "../Section.astro";
import type { Translations } from "@/i18n";

interface Props {
	t: Translations["education"];
	className?: string;
}

const { t, className } = Astro.props;

const allCertificates = [...t.mainCertificates, ...t.otherCertificates];
---

<Section className={className} title={t.title}>
	<ul class="space-y-4 py-3 print:space-y-0">
		{
			t.education.map(({ institution, startDate, endDate, area, url }) => {
				const startYear = new Date(startDate).getFullYear();
				const endYear = endDate != null ? new Date(endDate).getFullYear() : "Actual";
				const years = `${startYear} - ${endYear}`;

				return (
					<div class="flex items-center">
						<img src="/udg-logo.png" alt="Universidad de Guadalajara" class="mr-2 hidden h-8 w-8 rounded-sm object-contain md:inline-block print:inline-block" />
						<div class="relative w-full items-baseline justify-between gap-2">
							<h3 class="mr-6 items-baseline gap-x-2 gap-y-0.5 font-medium">
								<a target="_blank" class="hover:text-skin-hue group flex items-center gap-[6px] decoration-dotted underline-offset-[5px] hover:underline" href={url}>
									{institution}
								</a>
							</h3>
							<div class="text-sm text-skin-muted">{area}</div>
							<time class="right-0 top-0 text-xs text-skin-muted md:absolute md:block">{years}</time>
						</div>
					</div>
				);
			})
		}
	</ul>

	{
		allCertificates.length > 0 && (
			<div x-data="{ expanded: false }">
				<h4>{t.certificatesTitle}</h4>
				<ul class="space-y-4 py-3 print:space-y-0">
					{t.mainCertificates.map(({ name, date, issuer, url }) => {
						const certificateYear = new Date(date).getFullYear();
						return (
							<div class="flex items-baseline">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 hidden h-5 w-5 self-start md:inline-block print:hidden">
									<path d="M15 12h-5" />
									<path d="M15 8h-5" />
									<path d="M19 17V5a2 2 0 0 0-2-2H4" />
									<path d="M8 21h12a2 2 0 0 0 2-2v-1a1 1 0 0 0-1-1H11a1 1 0 0 0-1 1v1a2 2 0 1 1-4 0V5a2 2 0 1 0-4 0v2a1 1 0 0 0 1 1h3" />
								</svg>
								<div class="relative w-full items-baseline justify-between gap-2">
									<h3 class="mr-6 items-baseline gap-x-2 gap-y-0.5 font-medium">
										{url ? (
											<a class="hover:text-skin-hue group flex items-center gap-[6px] text-skin-base decoration-dotted underline-offset-[5px] hover:underline" href={url} target="_blank">
												{name}
											</a>
										) : (
											<span>{name}</span>
										)}
									</h3>
									<div class="text-sm text-skin-muted">{issuer}</div>
									<time class="right-0 top-0 text-xs text-skin-muted md:absolute md:block">{certificateYear}</time>
								</div>
							</div>
						);
					})}
				</ul>

				<ul class="space-y-4 py-3 print:space-y-0" x-show="expanded" x-collapse>
					{t.otherCertificates.map(({ name, date, issuer, url }) => {
						const certificateYear = new Date(date).getFullYear();
						return (
							<div class="flex items-baseline">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 hidden h-5 w-5 self-start md:inline-block print:hidden">
									<path d="M15 12h-5" />
									<path d="M15 8h-5" />
									<path d="M19 17V5a2 2 0 0 0-2-2H4" />
									<path d="M8 21h12a2 2 0 0 0 2-2v-1a1 1 0 0 0-1-1H11a1 1 0 0 0-1 1v1a2 2 0 1 1-4 0V5a2 2 0 1 0-4 0v2a1 1 0 0 0 1 1h3" />
								</svg>
								<div class="relative w-full items-baseline justify-between gap-2">
									<h3 class="mr-6 items-baseline gap-x-2 gap-y-0.5 font-medium">
										{url ? (
											<a class="hover:text-skin-hue group flex items-center gap-[6px] text-skin-base decoration-dotted underline-offset-[5px] hover:underline" href={url} target="_blank">
												{name}
											</a>
										) : (
											<span>{name}</span>
										)}
									</h3>
									<div class="text-sm text-skin-muted">{issuer}</div>
									<time class="right-0 top-0 text-xs text-skin-muted md:absolute md:block">{certificateYear}</time>
								</div>
							</div>
						);
					})}
				</ul>

				<button
					@click="expanded = !expanded"
					class="print:hidden group/more mt-2 w-fit cursor-pointer items-center justify-center gap-1.5 text-xs underline text-skin-muted transition-all hover:text-skin-base flex"
				>
					<span x-text={`expanded ? '${t.labels.showLess}' : '${t.labels.showMore} (${t.otherCertificates.length})'`}>{t.labels.showMore} ({t.otherCertificates.length})</span>
					<svg class="w-4 h-4 group-hover/more:translate-y-0.5 duration-200 ease-out" :class="{ 'rotate-180': expanded }" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
				</button>
			</div>
		)
	}
</Section>
