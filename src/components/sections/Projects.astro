---
import Section from "../Section.astro";
import type { Translations } from "@/i18n";

interface Props {
	t: Translations["projects"];
	className?: string;
}

const { t, className } = Astro.props;

const VISIBLE_COUNT = 4;
const visibleItems = t.items.slice(0, VISIBLE_COUNT);
const hiddenItems = t.items.slice(VISIBLE_COUNT);
---

{t.items.length > 0 && (
<Section className={className} title={t.title}>
	<div x-data="{ expanded: false }">
		<div class="grid grid-cols-1 gap-4 md:grid-cols-2 print:flex print:flex-col">
			{
				visibleItems.map(({ url, description, highlights, name, isActive, github, image, skills }) => (
					<div x-data="{ open: false }">
						<button
							@click="open = true"
							class="ring-skin-muted group relative flex w-full cursor-pointer flex-col overflow-hidden rounded-lg bg-skin-button-muted/50 text-left shadow-sm ring-1 transition-all hover:shadow-md hover:ring-skin-hue/50"
						>
							{image && (
								<div class="overflow-hidden">
									<img
										src={image}
										alt={name}
										class="aspect-video w-full object-cover object-top transition-transform duration-300 group-hover:scale-105"
										loading="lazy"
									/>
								</div>
							)}
							<div class="flex flex-1 flex-col p-5">
								<div class="flex items-center gap-2">
									{!image && (
										<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-folder size-4 shrink-0 text-skin-hue">
											<path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z" />
										</svg>
									)}
									<span class="text-lg font-medium text-skin-base transition-colors group-hover:text-skin-hue">{name}</span>
								</div>
								<p class="mt-2 line-clamp-2 text-sm text-skin-muted">{description}</p>
								{skills && skills.length > 0 && (
									<div class="mt-3 flex flex-wrap gap-1.5">
										{skills.map((skill: string) => (
											<span class="rounded-full bg-skin-hue/10 px-2.5 py-0.5 text-xs font-medium text-skin-hue">{skill}</span>
										))}
									</div>
								)}
							</div>
						</button>

						<div
							x-show="open"
							x-transition:enter="transition ease-out duration-200"
							x-transition:enter-start="opacity-0"
							x-transition:enter-end="opacity-100"
							x-transition:leave="transition ease-in duration-150"
							x-transition:leave-start="opacity-100"
							x-transition:leave-end="opacity-0"
							@click="open = false"
							@keydown.escape.window="open = false"
							class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 p-4 backdrop-blur-sm"
							style="display: none;"
							x-cloak
						>
							<div
								x-show="open"
								x-transition:enter="transition ease-out duration-200"
								x-transition:enter-start="opacity-0 scale-95 translate-y-4"
								x-transition:enter-end="opacity-100 scale-100 translate-y-0"
								x-transition:leave="transition ease-in duration-150"
								x-transition:leave-start="opacity-100 scale-100 translate-y-0"
								x-transition:leave-end="opacity-0 scale-95 translate-y-4"
								class="relative max-h-[90vh] w-full max-w-2xl overflow-y-auto rounded-xl bg-skin-fill shadow-2xl ring-1 ring-skin-muted"
								@click.stop
							>
								<button
									@click="open = false"
									class="absolute right-3 top-3 z-10 flex h-8 w-8 items-center justify-center rounded-full bg-black/40 text-white backdrop-blur-sm transition-colors hover:bg-black/60"
									aria-label={t.labels.close}
								>
									<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M18 6 6 18" />
										<path d="m6 6 12 12" />
									</svg>
								</button>

								{image && (
									<img src={image} alt={name} class="w-full rounded-t-xl object-cover object-top" />
								)}

								<div class="flex flex-col gap-4 p-6">
									<div>
										<h3 class="text-2xl font-bold">{name}</h3>
										<p class="mt-2 text-sm leading-relaxed text-skin-muted">{description}</p>
									</div>

									{highlights.length > 0 && (
										<ul class="modal-highlights space-y-1.5 text-sm text-skin-muted">
											{highlights.map((h: string) => (
												<li class="flex items-start gap-2">
													<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 text-skin-hue"><polyline points="20 6 9 17 4 12" /></svg>
													<span>{h}</span>
												</li>
											))}
										</ul>
									)}

									{skills && skills.length > 0 && (
										<div class="flex flex-wrap gap-2">
											{skills.map((skill: string) => (
												<span class="rounded-full bg-skin-hue/10 px-3 py-1 text-xs font-medium text-skin-hue">{skill}</span>
											))}
										</div>
									)}

									<div class="flex flex-wrap gap-3 border-t border-skin-muted/30 pt-4">
										{isActive && url && (
											<a href={url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg bg-skin-button-accent px-4 py-2.5 text-sm font-medium text-skin-inverted transition-colors hover:opacity-90">
												<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" /><polyline points="15 3 21 3 21 9" /><line x1="10" x2="21" y1="14" y2="3" /></svg>
												{t.labels.visit}
											</a>
										)}
										{github && (
											<a href={github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg px-4 py-2.5 text-sm font-medium text-skin-base ring-1 ring-skin-muted transition-colors hover:bg-skin-button-muted hover:ring-skin-hue/50">
												<svg width="16" height="16" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" /></svg>
												{t.labels.repo}
											</a>
										)}
									</div>
								</div>
							</div>
						</div>
					</div>
				))
			}
		</div>

		{hiddenItems.length > 0 && (
			<div x-show="expanded" x-collapse class="mt-4">
				<div class="grid grid-cols-1 gap-4 md:grid-cols-2 print:flex print:flex-col">
					{
						hiddenItems.map(({ url, description, highlights, name, isActive, github, image, skills }) => (
							<div x-data="{ open: false }">
								<button
									@click="open = true"
									class="ring-skin-muted group relative flex w-full cursor-pointer flex-col overflow-hidden rounded-lg bg-skin-button-muted/50 text-left shadow-sm ring-1 transition-all hover:shadow-md hover:ring-skin-hue/50"
								>
									{image && (
										<div class="overflow-hidden">
											<img
												src={image}
												alt={name}
												class="aspect-video w-full object-cover object-top transition-transform duration-300 group-hover:scale-105"
												loading="lazy"
											/>
										</div>
									)}
									<div class="flex flex-1 flex-col p-5">
										<div class="flex items-center gap-2">
											{!image && (
												<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-folder size-4 shrink-0 text-skin-hue">
													<path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z" />
												</svg>
											)}
											<span class="text-lg font-medium text-skin-base transition-colors group-hover:text-skin-hue">{name}</span>
										</div>
										<p class="mt-2 line-clamp-2 text-sm text-skin-muted">{description}</p>
										{skills && skills.length > 0 && (
											<div class="mt-3 flex flex-wrap gap-1.5">
												{skills.map((skill: string) => (
													<span class="rounded-full bg-skin-hue/10 px-2.5 py-0.5 text-xs font-medium text-skin-hue">{skill}</span>
												))}
											</div>
										)}
									</div>
								</button>

								<div
									x-show="open"
									x-transition:enter="transition ease-out duration-200"
									x-transition:enter-start="opacity-0"
									x-transition:enter-end="opacity-100"
									x-transition:leave="transition ease-in duration-150"
									x-transition:leave-start="opacity-100"
									x-transition:leave-end="opacity-0"
									@click="open = false"
									@keydown.escape.window="open = false"
									class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 p-4 backdrop-blur-sm"
									style="display: none;"
									x-cloak
								>
									<div
										x-show="open"
										x-transition:enter="transition ease-out duration-200"
										x-transition:enter-start="opacity-0 scale-95 translate-y-4"
										x-transition:enter-end="opacity-100 scale-100 translate-y-0"
										x-transition:leave="transition ease-in duration-150"
										x-transition:leave-start="opacity-100 scale-100 translate-y-0"
										x-transition:leave-end="opacity-0 scale-95 translate-y-4"
										class="relative max-h-[90vh] w-full max-w-2xl overflow-y-auto rounded-xl bg-skin-fill shadow-2xl ring-1 ring-skin-muted"
										@click.stop
									>
										<button
											@click="open = false"
											class="absolute right-3 top-3 z-10 flex h-8 w-8 items-center justify-center rounded-full bg-black/40 text-white backdrop-blur-sm transition-colors hover:bg-black/60"
											aria-label={t.labels.close}
										>
											<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
												<path d="M18 6 6 18" />
												<path d="m6 6 12 12" />
											</svg>
										</button>

										{image && (
											<img src={image} alt={name} class="w-full rounded-t-xl object-cover object-top" />
										)}

										<div class="flex flex-col gap-4 p-6">
											<div>
												<h3 class="text-2xl font-bold">{name}</h3>
												<p class="mt-2 text-sm leading-relaxed text-skin-muted">{description}</p>
											</div>

											{highlights.length > 0 && (
												<ul class="modal-highlights space-y-1.5 text-sm text-skin-muted">
													{highlights.map((h: string) => (
														<li class="flex items-start gap-2">
															<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 text-skin-hue"><polyline points="20 6 9 17 4 12" /></svg>
															<span>{h}</span>
														</li>
													))}
												</ul>
											)}

											{skills && skills.length > 0 && (
												<div class="flex flex-wrap gap-2">
													{skills.map((skill: string) => (
														<span class="rounded-full bg-skin-hue/10 px-3 py-1 text-xs font-medium text-skin-hue">{skill}</span>
													))}
												</div>
											)}

											<div class="flex flex-wrap gap-3 border-t border-skin-muted/30 pt-4">
												{isActive && url && (
													<a href={url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg bg-skin-button-accent px-4 py-2.5 text-sm font-medium text-skin-inverted transition-colors hover:opacity-90">
														<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" /><polyline points="15 3 21 3 21 9" /><line x1="10" x2="21" y1="14" y2="3" /></svg>
														{t.labels.visit}
													</a>
												)}
												{github && (
													<a href={github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg px-4 py-2.5 text-sm font-medium text-skin-base ring-1 ring-skin-muted transition-colors hover:bg-skin-button-muted hover:ring-skin-hue/50">
														<svg width="16" height="16" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" /></svg>
														{t.labels.repo}
													</a>
												)}
											</div>
										</div>
									</div>
								</div>
							</div>
						))
					}
				</div>
			</div>
		)}

		{hiddenItems.length > 0 && (
			<button
				@click="expanded = !expanded"
				class="print:hidden group/more mt-4 w-fit cursor-pointer items-center justify-center gap-1.5 text-xs underline text-skin-muted transition-all hover:text-skin-base flex"
			>
				<span x-text={`expanded ? '${t.labels.showLess}' : '${t.labels.showMore} (${hiddenItems.length})'`}>{t.labels.showMore} ({hiddenItems.length})</span>
				<svg class="h-4 w-4 duration-200 ease-out group-hover/more:translate-y-0.5" :class="{ 'rotate-180': expanded }" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
			</button>
		)}
	</div>
</Section>
)}

<style>
	.modal-highlights {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	[x-cloak] {
		display: none !important;
	}
</style>
